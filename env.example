# Personal AI Agent — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real keys.

# Required: Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_key_here

# Web search uses SearXNG (self-hosted, no key needed) with a DuckDuckGo fallback.
# No API keys are required for search. See SEARXNG_SETUP.md to spin up SearXNG
# locally with Docker in one command.

# GitHub personal access token — needs repo scope.
# Create at https://github.com/settings/tokens (classic token → select "repo").
# Used by the github_* tools for repository management (Phase 5a).
GITHUB_TOKEN=your_github_token_here
