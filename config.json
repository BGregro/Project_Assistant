{
  "llm": {
    "primary": "claude-haiku-4-5",
    "complex": "claude-sonnet-4-6",
    "local": "qwen2.5:14b",
    "local_agent": "qwen2.5:14b",
    "max_tokens_primary": 8192,
    "max_tokens_complex": 16000
  },
  "use_prompt_optimizer": true,
  "use_intent_routing": true,
  "use_tool_compression": true,
  "use_code_prevalidation": true,
  "use_tool_prefilter": false,
  "local_fallback": true,
  "local_mode": false,
  "local_agent_timeout": 300,
  "ollama_base_url": "http://localhost:11434",
  "outputs_dir": "outputs",
  "tree_root": ".",
  "permissions": {
    "require_confirmation_for_write": true,
    "require_confirmation_for_delete": true,
    "allowed_directories": []
  },
  "context": {
    "max_history_turns": 20,
    "max_iterations_per_turn": 100,
    "recent_turns": 4,
    "summary_threshold": 4,
    "retrieval_n": 3,
    "similarity_cutoff": 0.45,
    "compression_threshold": 6000
  },
  "embeddings": {
    "enabled": true,
    "model": "nomic-embed-text"
  },
  "tools": {
    "web": {
      "max_results": 5,
      "fetch_timeout": 10,
      "max_fetch_chars": 8000,
      "searxng_url": "http://localhost:8888"
    },
    "code": {
      "timeout_seconds": 30
    }
  }
}
